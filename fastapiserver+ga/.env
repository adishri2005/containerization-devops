# =============================================================================
# .env — Environment Variables (LOCAL USE ONLY — NOT committed to Git)
# =============================================================================
# This file stores sensitive configuration values as key=value pairs.
# It is listed in .gitignore so it never gets pushed to GitHub.
#
# DOCKERTOKEN is the Personal Access Token (PAT) generated from Docker Hub
# (https://hub.docker.com/settings/security). It allows authentication
# without using your Docker Hub password.
#
# In the CI/CD pipeline (GitHub Actions), this token is stored as a
# GitHub Secret (repo → Settings → Secrets), NOT read from this file.
# This .env file is only for local development reference.
# =============================================================================
DOCKERTOKEN=tokengeneratedfromdockerhub
